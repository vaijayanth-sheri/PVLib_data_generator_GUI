{
  "name": "pvlib-gui",
  "framework": "vite",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": [
        "node_modules/**",
        ".vercel/**/tests/**",
        ".vercel/**/test/**",
        ".vercel/**/__pycache__/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

{
  "name": "pvlib-gui",
  "framework": "vite",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "**/tests/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

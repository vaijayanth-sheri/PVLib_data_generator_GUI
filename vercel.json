{
  "name": "pvlib-gui",
  "framework": "vite",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules/**,**/*/tests/**,**/*/test/**,**/*/__pycache__/**,**/*.c,**/*.h,**/*.cpp,**/*.pyx,**/*.pxd,**/*.pyc}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
